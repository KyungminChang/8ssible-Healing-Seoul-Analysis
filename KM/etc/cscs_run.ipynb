import pandas as pd
import numpy as np
from pathlib import Path

# =========================================================
# 0) Runtime config
# =========================================================
RUN_MODE = "folder_monthly"  # "single" | "folder_monthly"

INPUT_PATH = Path(r"E:\project\data\input_data.txt")
INPUT_DIR = Path(r"E:\project\data\monthly")
FILE_PATTERN = "*.txt"

OUTPUT_DIR = Path(r"E:\project\output")
OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

USE_COLS = [
    "start_dt", "arv_dt", "start_emd", "arv_emd",
    "start_arv_place_type", "mvmn_time_sum", "popl_cnt",
]

PRIORITY_GROUPS = [["HW", "WH"], ["HE", "EH"], ["WE", "EW"], ["HH", "WW", "EE"]]
TARGET_RATIO = 0.60
YEAR_FROM, YEAR_TO = 2022, 2024
FILTER_H_INCLUDED = True
USE_SEOUL_DIRECTION_FILTER = True
SEOUL_PREFIX = "11"

FEATURE_COLS = ["total_pop", "avg_time", "total_time"]
LITERATURE_WEIGHTS = {"pop": 0.45, "avg": 0.35, "total": 0.20}
REG_TARGET_COL = None

TXT_SEP = ","  # 파이프(|)면 "|", 탭이면 "\t" 로 변경


# =========================================================
# 2) I/O helpers
# =========================================================
def load_raw_input(path: Path) -> pd.DataFrame:
    # [진단 1] 구분자·인코딩 자동 처리 — 원인 불명확 시 여기서 FAIL 메시지 확인
    ext = path.suffix.lower()
    sep = TXT_SEP if ext == ".txt" else ","
    for enc in ["utf-8", "cp949", "euc-kr"]:
        try:
            df = pd.read_csv(path, sep=sep, encoding=enc)
            return df
        except UnicodeDecodeError:
            continue
    raise ValueError(f"인코딩 자동 감지 실패: {path.name}  (TXT_SEP='{TXT_SEP}' 도 확인)")


def collect_input_files(input_dir: Path, file_pattern: str = "*.txt") -> list[Path]:
    files = sorted(input_dir.glob(file_pattern))
    if not files:
        raise FileNotFoundError(f"No input files found in {input_dir}")
    return files


# =========================================================
# 3) Numeric helpers
# =========================================================
def minmax(s: pd.Series) -> pd.Series:
    lo = s.min()
    hi = s.max()
    if pd.isna(lo) or pd.isna(hi) or hi == lo:
        return pd.Series(0.0, index=s.index)
    return (s - lo) / (hi - lo)


def normalize_weights(w: dict) -> dict:
    total = float(sum(w.values()))
    if total == 0:
        n = len(w)
        return {k: 1.0 / n for k in w}
    return {k: float(v) / total for k, v in w.items()}


def rank_spearman(df_a, df_b, key="gu", col="stress_score"):
    a = df_a[[key, col]].rename(columns={col: "a"})
    b = df_b[[key, col]].rename(columns={col: "b"})
    m = a.merge(b, on=key, how="inner")
    if len(m) < 2:
        return np.nan
    return m["a"].rank().corr(m["b"].rank(), method="pearson")


def topk_overlap(df_a, df_b, k=5, key="gu", col="stress_score"):
    if k <= 0:
        return np.nan
    sa = set(df_a.nlargest(k, col)[key])
    sb = set(df_b.nlargest(k, col)[key])
    return len(sa & sb) / k


# =========================================================
# 4) Preprocess / features / weights
# =========================================================
def preprocess_movement(raw_df: pd.DataFrame) -> pd.DataFrame:
    df = raw_df[USE_COLS].copy()

    df["start_dt"] = pd.to_datetime(df["start_dt"], errors="coerce")
    df["arv_dt"] = pd.to_datetime(df["arv_dt"], errors="coerce")
    df["start_emd"] = df["start_emd"].astype(str).str.strip()
    df["arv_emd"] = df["arv_emd"].astype(str).str.strip()
    df["start_arv_place_type"] = df["start_arv_place_type"].astype(str).str.upper().str.strip()
    df["mvmn_time_sum"] = pd.to_numeric(df["mvmn_time_sum"], errors="coerce")
    df["popl_cnt"] = pd.to_numeric(df["popl_cnt"], errors="coerce")

    df = df.dropna(subset=["start_dt", "mvmn_time_sum", "popl_cnt"])
    df = df[df["start_dt"].dt.year.between(YEAR_FROM, YEAR_TO)]

    df["year"] = df["start_dt"].dt.year.astype("int16")
    df["month"] = df["start_dt"].dt.month.astype("int8")
    df["start_gu"] = df["start_emd"].str[:5]
    df["arv_gu"] = df["arv_emd"].str[:5]

    if FILTER_H_INCLUDED:
        df = df[df["start_arv_place_type"].str.contains("H", na=False)]

    if USE_SEOUL_DIRECTION_FILTER:
        d = df.copy()
        d["start_is_seoul"] = d["start_gu"].str.startswith(SEOUL_PREFIX)
        d["arv_is_seoul"] = d["arv_gu"].str.startswith(SEOUL_PREFIX)
        inbound = d["start_arv_place_type"].isin(["HW", "HE"]) & d["arv_is_seoul"]
        outbound = d["start_arv_place_type"].isin(["WH", "EH"]) & d["start_is_seoul"]
        df = d.loc[inbound | outbound].copy()

    return df


def select_place_types_by_priority(df: pd.DataFrame, target_ratio=0.60):
    pop_by_type = df.groupby("start_arv_place_type", observed=True)["popl_cnt"].sum()
    total_pop = float(pop_by_type.sum())
    if total_pop <= 0:
        return df.iloc[0:0].copy(), [], 0.0

    selected_types: list[str] = []
    selected_pop = 0.0
    for group in PRIORITY_GROUPS:
        selected_types.extend(group)
        selected_pop += float(pop_by_type.reindex(group).fillna(0.0).sum())
        if selected_pop / total_pop >= target_ratio:
            break

    filtered_df = df[df["start_arv_place_type"].isin(selected_types)].copy()
    return filtered_df, selected_types, selected_pop / total_pop


def make_features(df: pd.DataFrame, group_col="arv_gu") -> pd.DataFrame:
    f = (
        df.groupby(group_col, dropna=False, observed=True)
        .agg(total_pop=("popl_cnt", "sum"), avg_time=("mvmn_time_sum", "mean"))
        .reset_index()
        .rename(columns={group_col: "gu"})
    )
    f["total_time"] = f["total_pop"] * f["avg_time"]
    return f


def pca_weights(feature_df: pd.DataFrame) -> dict:
    if feature_df.empty:
        return normalize_weights(LITERATURE_WEIGHTS)
    X = feature_df[FEATURE_COLS].astype(float).replace([np.inf, -np.inf], np.nan).dropna()
    if len(X) < 2:
        return normalize_weights(LITERATURE_WEIGHTS)
    X = (X - X.mean()) / X.std(ddof=0).replace(0, np.nan)
    X = X.fillna(0.0)
    try:
        cov = np.cov(X.values, rowvar=False)
        eigvals, eigvecs = np.linalg.eigh(cov)
        pc1 = eigvecs[:, np.argmax(eigvals)]
        load = np.abs(pc1)
        return normalize_weights({"pop": load[0], "avg": load[1], "total": load[2]})
    except Exception:
        return normalize_weights(LITERATURE_WEIGHTS)


def critic_weights(feature_df: pd.DataFrame) -> dict:
    if feature_df.empty:
        return normalize_weights(LITERATURE_WEIGHTS)
    Z = feature_df[FEATURE_COLS].astype(float)
    Z = (Z - Z.min()) / (Z.max() - Z.min())
    Z = Z.fillna(0.0)
    std = Z.std(ddof=0)
    corr = Z.corr().fillna(0.0)
    cvals = {c: std[c] * (1 - corr[c]).sum() for c in FEATURE_COLS}
    return normalize_weights({
        "pop": cvals["total_pop"],
        "avg": cvals["avg_time"],
        "total": cvals["total_time"],
    })


def regression_weights(feature_df: pd.DataFrame, target_col: str | None) -> dict | None:
    if not target_col or target_col not in feature_df.columns:
        return None
    d = feature_df.dropna(subset=FEATURE_COLS + [target_col]).copy()
    if len(d) < 5:
        return None
    X = d[FEATURE_COLS].astype(float)
    y = pd.to_numeric(d[target_col], errors="coerce")
    valid = y.notna()
    X, y = X[valid], y[valid]
    if len(X) < 5:
        return None
    Xz = (X - X.mean()) / X.std(ddof=0).replace(0, np.nan)
    Xz = Xz.fillna(0.0)
    ystd = y.std(ddof=0)
    yz = (y - y.mean()) / (ystd if ystd != 0 else 1.0)
    beta, *_ = np.linalg.lstsq(Xz.values, yz.values, rcond=None)
    beta = np.abs(beta)
    return normalize_weights({"pop": beta[0], "avg": beta[1], "total": beta[2]})


def score_with_weights(feature_df: pd.DataFrame, weights: dict, model_name: str) -> pd.DataFrame:
    d = feature_df.copy()
    d["pop_norm"] = minmax(d["total_pop"])
    d["avg_norm"] = minmax(d["avg_time"])
    d["total_norm"] = minmax(d["total_time"])
    w = normalize_weights(weights)
    d["stress_score"] = (
        d["pop_norm"] * w["pop"]
        + d["avg_norm"] * w["avg"]
        + d["total_norm"] * w["total"]
    ) * 100
    d["model"] = model_name
    d["w_pop"] = w["pop"]
    d["w_avg"] = w["avg"]
    d["w_total"] = w["total"]
    return d.sort_values("stress_score", ascending=False).reset_index(drop=True)


# =========================================================
# 5) Core pipeline outputs
# =========================================================
def run_pipeline_from_preprocessed(pre_df: pd.DataFrame, raw_rows: int):
    d_sel, selected_types, coverage = select_place_types_by_priority(pre_df, TARGET_RATIO)

    if d_sel.empty:
        meta = pd.DataFrame([{
            "year_range": f"{YEAR_FROM}~{YEAR_TO}",
            "h_filter": FILTER_H_INCLUDED,
            "selected_types": "",
            "coverage": 0.0,
            "raw_rows": raw_rows,
            "filtered_rows": 0,
        }])
        return {
            "meta": meta,
            "selected_data": d_sel,
            "all_scores": pd.DataFrame(),
            "sensitivity": pd.DataFrame(),
            "yearly_stability": pd.DataFrame(),
            "yearly_lit_scores": pd.DataFrame(),
        }

    f = make_features(d_sel, "arv_gu")
    w_lit = normalize_weights(LITERATURE_WEIGHTS)
    w_pca = pca_weights(f)
    w_critic = critic_weights(f)
    w_reg = regression_weights(f, REG_TARGET_COL)

    score_frames = [
        score_with_weights(f, w_lit, "literature"),
        score_with_weights(f, w_pca, "pca"),
        score_with_weights(f, w_critic, "critic"),
    ]
    if w_reg is not None:
        score_frames.append(score_with_weights(f, w_reg, "regression"))

    all_scores = pd.concat(score_frames, ignore_index=True)

    base = all_scores[all_scores["model"] == "literature"].copy()
    sensitivity = pd.DataFrame([
        {
            "model": m,
            "spearman_vs_lit": rank_spearman(base, all_scores[all_scores["model"] == m].copy()),
            "top5_overlap_vs_lit": topk_overlap(base, all_scores[all_scores["model"] == m].copy(), k=5),
        }
        for m in all_scores["model"].unique()
    ])

    yearly = (
        d_sel.groupby(["year", "arv_gu"], as_index=False, observed=True)
        .agg(total_pop=("popl_cnt", "sum"), avg_time=("mvmn_time_sum", "mean"))
        .rename(columns={"arv_gu": "gu"})
    )
    yearly["total_time"] = yearly["total_pop"] * yearly["avg_time"]

    yearly_parts = []
    for y in sorted(yearly["year"].unique()):
        ydf = yearly[yearly["year"] == y].copy()
        sy = score_with_weights(ydf[["gu", "total_pop", "avg_time", "total_time"]], w_lit, f"literature_{y}")
        sy["year"] = y
        yearly_parts.append(sy[["year", "gu", "stress_score"]])

    yearly_lit_scores = pd.concat(yearly_parts, ignore_index=True) if yearly_parts else pd.DataFrame()

    stability_rows = []
    years = sorted(yearly_lit_scores["year"].unique()) if len(yearly_lit_scores) else []
    for i in range(len(years)):
        for j in range(i + 1, len(years)):
            y1, y2 = years[i], years[j]
            a = yearly_lit_scores[yearly_lit_scores["year"] == y1]
            b = yearly_lit_scores[yearly_lit_scores["year"] == y2]
            stability_rows.append({"year_pair": f"{y1}-{y2}", "spearman": rank_spearman(a, b)})

    meta = pd.DataFrame([{
        "year_range": f"{YEAR_FROM}~{YEAR_TO}",
        "h_filter": FILTER_H_INCLUDED,
        "selected_types": ", ".join(selected_types),
        "coverage": coverage,
        "raw_rows": raw_rows,
        "filtered_rows": len(d_sel),
    }])

    return {
        "meta": meta,
        "selected_data": d_sel,
        "all_scores": all_scores,
        "sensitivity": sensitivity,
        "yearly_stability": pd.DataFrame(stability_rows),
        "yearly_lit_scores": yearly_lit_scores,
    }


def run_pipeline_all(raw_df: pd.DataFrame):
    d = preprocess_movement(raw_df)
    return run_pipeline_from_preprocessed(d, raw_rows=len(raw_df))


# =========================================================
# 6) One-pass folder runner (single scan)
# =========================================================
def run_folder_monthly_once(input_dir: Path, file_pattern: str = "*.txt"):
    files = collect_input_files(input_dir, file_pattern)
    print(f"[INFO] Files found: {len(files)}")

    agg_parts = []
    score_parts = []
    file_log = []
    pre_parts = []
    total_raw_rows = 0
    w = normalize_weights(LITERATURE_WEIGHTS)

    for i, fp in enumerate(files, start=1):
        print(f"[{i}/{len(files)}] {fp.name}", end="  ")
        try:
            raw_df = load_raw_input(fp)
            total_raw_rows += len(raw_df)

            # [진단 2] 첫 파일에서만 컬럼·형식 확인
            if i == 1:
                print(f"\n  columns: {list(raw_df.columns)}")
                print(f"  shape  : {raw_df.shape}")
                print(f"  head(1):\n{raw_df.head(1).to_string()}")

            pre = preprocess_movement(raw_df)
            pre_parts.append(pre)

            if pre.empty:
                file_log.append({"file": fp.name, "raw_rows": len(raw_df), "filtered_rows": 0, "status": "EMPTY"})
                print(f"EMPTY (raw={len(raw_df):,})")
                continue

            pre["yyyymm"] = pre["start_dt"].dt.to_period("M").astype(str)
            pre["total_time_weighted"] = pre["mvmn_time_sum"] * pre["popl_cnt"]

            monthly = (
                pre.groupby(["yyyymm", "start_gu", "arv_gu", "start_arv_place_type"], as_index=False, observed=True)
                .agg(total_pop=("popl_cnt", "sum"), total_time_weighted=("total_time_weighted", "sum"))
            )
            agg_parts.append(monthly)

            g = (
                pre.groupby(["year", "month", "arv_gu"], as_index=False, observed=True)
                .agg(total_pop=("popl_cnt", "sum"), avg_time=("mvmn_time_sum", "mean"))
                .rename(columns={"arv_gu": "target_gu"})
            )
            g["total_time"] = g["total_pop"] * g["avg_time"]
            grp = g.groupby(["year", "month"], observed=True)
            g["pop_norm"] = grp["total_pop"].transform(minmax)
            g["avg_norm"] = grp["avg_time"].transform(minmax)
            g["total_norm"] = grp["total_time"].transform(minmax)
            g["stress_score"] = (
                g["pop_norm"] * w["pop"]
                + g["avg_norm"] * w["avg"]
                + g["total_norm"] * w["total"]
            ) * 100
            score_parts.append(g[["year", "month", "target_gu", "stress_score"]])

            print(f"OK  raw={len(raw_df):,}  filtered={len(pre):,}")
            file_log.append({"file": fp.name, "raw_rows": len(raw_df), "filtered_rows": len(pre), "status": "OK"})
        except Exception as e:
            print(f"ERROR: {e}")
            file_log.append({"file": fp.name, "raw_rows": np.nan, "filtered_rows": np.nan, "status": f"ERROR: {e}"})

    file_log_df = pd.DataFrame(file_log)

    # [진단 3] 루프 종료 후 파일별 처리 결과 요약
    print("\n[파일 처리 요약]")
    print(file_log_df[["file", "raw_rows", "filtered_rows", "status"]].to_string(index=False))

    if agg_parts:
        all_monthly = pd.concat(agg_parts, ignore_index=True)
        monthly_agg_df = (
            all_monthly.groupby(["yyyymm", "start_gu", "arv_gu", "start_arv_place_type"], as_index=False, observed=True)
            .agg(total_pop=("total_pop", "sum"), total_time_weighted=("total_time_weighted", "sum"))
        )
        monthly_agg_df["avg_travel_time"] = monthly_agg_df["total_time_weighted"] / monthly_agg_df["total_pop"]
        monthly_summary_df = (
            monthly_agg_df.groupby("yyyymm", as_index=False, observed=True)
            .agg(total_pop=("total_pop", "sum"))
            .sort_values("yyyymm")
        )
    else:
        monthly_agg_df = pd.DataFrame()
        monthly_summary_df = pd.DataFrame()

    if score_parts:
        monthly_commute_score_df = pd.concat(score_parts, ignore_index=True)
        monthly_commute_score_df = (
            monthly_commute_score_df.groupby(["year", "month", "target_gu"], as_index=False, observed=True)
            .agg(stress_score=("stress_score", "mean"))
            .sort_values(["year", "month", "target_gu"])
            .reset_index(drop=True)
        )
    else:
        monthly_commute_score_df = pd.DataFrame(columns=["year", "month", "target_gu", "stress_score"])

    pre_all = pd.concat(pre_parts, ignore_index=True) if pre_parts else pd.DataFrame(columns=USE_COLS)
    combined_outputs = run_pipeline_from_preprocessed(pre_all, raw_rows=total_raw_rows) if len(pre_all) else {
        "meta": pd.DataFrame(),
        "selected_data": pd.DataFrame(),
        "all_scores": pd.DataFrame(),
        "sensitivity": pd.DataFrame(),
        "yearly_stability": pd.DataFrame(),
        "yearly_lit_scores": pd.DataFrame(),
    }

    return combined_outputs, monthly_agg_df, monthly_summary_df, monthly_commute_score_df, file_log_df


# =========================================================
# 7) Entrypoint  (if __name__ 제거 — Jupyter에서 직접 실행 가능)
# =========================================================
if RUN_MODE == "single":
    raw_df = load_raw_input(INPUT_PATH)
    outputs = run_pipeline_all(raw_df)

    outputs["meta"].to_csv(OUTPUT_DIR / "00_메타정보.txt", index=False, encoding="utf-8-sig")
    outputs["selected_data"].to_csv(OUTPUT_DIR / "01_전처리후_선정데이터.txt", index=False, encoding="utf-8-sig")
    outputs["all_scores"].to_csv(OUTPUT_DIR / "02_모형별_점수결과.txt", index=False, encoding="utf-8-sig")
    outputs["sensitivity"].to_csv(OUTPUT_DIR / "03_민감도분석.txt", index=False, encoding="utf-8-sig")
    outputs["yearly_stability"].to_csv(OUTPUT_DIR / "04_연도안정성분석.txt", index=False, encoding="utf-8-sig")
    outputs["yearly_lit_scores"].to_csv(OUTPUT_DIR / "05_연도별점수_문헌기반.txt", index=False, encoding="utf-8-sig")
    print("[DONE] Single mode complete")

elif RUN_MODE == "folder_monthly":
    outputs, monthly_agg_df, monthly_summary_df, monthly_commute_score_df, file_log_df = \
        run_folder_monthly_once(INPUT_DIR, FILE_PATTERN)

    save_map = {
        "00_메타정보.txt":              outputs["meta"],
        "01_전처리후_선정데이터.txt":   outputs["selected_data"],
        "02_모형별_점수결과.txt":       outputs["all_scores"],
        "03_민감도분석.txt":            outputs["sensitivity"],
        "04_연도안정성분석.txt":        outputs["yearly_stability"],
        "05_연도별점수_문헌기반.txt":   outputs["yearly_lit_scores"],
        "월별_통합집계.txt":            monthly_agg_df,
        "월별_요약.txt":                monthly_summary_df,
        "월별_파일처리로그.txt":        file_log_df,
        "월별_통근스트레스_점수.txt":   monthly_commute_score_df,
    }

    print("\n[저장]")
    for fname, df in save_map.items():
        df.to_csv(OUTPUT_DIR / fname, index=False, encoding="utf-8-sig")
        kb = (OUTPUT_DIR / fname).stat().st_size // 1024
        print(f"  {fname:<35} {len(df):>8,}행  {kb:>6,} KB")

    print(f"\n[DONE] → {OUTPUT_DIR}")

else:
    raise ValueError("RUN_MODE must be 'single' or 'folder_monthly'.")
